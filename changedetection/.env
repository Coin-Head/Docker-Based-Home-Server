# Setting a headful browser as the default for changedetection. Uses slightly more memory
BROWSER_URL=ws://browser-sockpuppet-chrome:3000/?headful=true


# Base URL for changedetection.io container.
# Example: http://localhost:5000
BASE_URL=https://changedetect.domain
